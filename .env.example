# Aliyun DashScope OpenAI-compatible credentials
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen-flash
EMBEDDING_MODEL=text-embedding-v4

# Local persistence
FAISS_PERSIST_DIRECTORY=data/faiss
UPLOAD_DIRECTORY=data/uploads

# Retrieval and ingestion
CHUNK_SIZE=800
CHUNK_OVERLAP=150
DEFAULT_TOP_K=4
MAX_TOP_K=10
# 归一化余弦相关性阈值；0.75 约等于原始余弦相似度不低于 0.5。
RELEVANCE_SCORE_THRESHOLD=0.75
MAX_UPLOAD_SIZE_BYTES=5242880
